# Public site origin used for canonical URLs, sitemap, and Open Graph.
# Local default is fine for development and CI.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Formspree form ID for the contact form (added in a later phase).
# Leave empty until the form is wired.
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# Optional Cloudflare Turnstile (later phase).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# When "true", draft MDX content appears in local/dev preview.
# Ignored in production builds — drafts never ship publicly.
SHOW_DRAFTS=false
